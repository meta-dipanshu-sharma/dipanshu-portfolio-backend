# ─────────────────────────────────────────────
# PORTFOLIO BACKEND — Environment Variables
# Copy this to .env.local and fill in values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────

# PostgreSQL — get from neon.tech (free)
DATABASE_URL="postgresql://user:password@host/portfolio?sslmode=require"

# Redis — get from upstash.com (free)
# Use the Redis REST URL format for Upstash
REDIS_HOST="your-redis-host.upstash.io"
REDIS_PORT="6379"
REDIS_PASSWORD="your-upstash-redis-password"
REDIS_TLS="true"

# Email — get from resend.com (free, 100 emails/day)
RESEND_API_KEY="re_xxxxxxxxxxxx"
CONTACT_EMAIL="dipanshusharma2510@gmail.com"
FROM_EMAIL="portfolio@yourdomain.com"

# Dashboard API key — generate with: openssl rand -hex 32
# This protects your private analytics endpoints
DASHBOARD_API_KEY="your-long-random-secret-key-here"

# Resume URL — where the PDF lives (your Vercel frontend public folder)
RESUME_URL="https://dipanshu-portfolio.vercel.app/DipanshuSharmaResume.pdf"

# Frontend URL — for CORS
FRONTEND_URL="https://dipanshu-portfolio.vercel.app"

# Port (Railway sets this automatically)
PORT=4000
